{
  "name": "alfred-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 -H 0.0.0.0",
    "dev:mock": "NEXT_PUBLIC_USE_MOCK_API=true next dev -p 3000 -H 0.0.0.0",
    "dev:mock:admin": "NEXT_PUBLIC_USE_MOCK_API=true NEXT_PUBLIC_MOCK_ROLE=ADMIN next dev -p 3000 -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "next": "15.5.9",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.9",
    "eslint-config-prettier": "^10",
    "jsdom": "^26.1.0",
    "prettier": "^3",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
